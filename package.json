{
  "name": "safepatrol-admin-tool",
  "version": "0.1.0",
  "description": "SafePatrol管理工具 - 桌面应用，基于Electron",
  "main": "main.js",

  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },

  "build": {
    "appId": "com.safepatrol.admin",
    "productName": "SafePatrolAdmin",

    "directories": {
      "output": "dist"
    },

    "files": [
      "**/*"
    ],

    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },

  "dependencies": {
    "exceljs": "^4.3.0",
    "sqlite3": "^5.1.6"
  },

  "devDependencies": {
    "electron-builder": "^24.0.0",
    "electron": "^26.0.0"
  }
}